# Microsoft 365 Migration Platform - Environment Variables

# Source Tenant
SOURCE_TENANT_ID=00000000-0000-0000-0000-000000000000
SOURCE_CLIENT_ID=11111111-1111-1111-1111-111111111111
SOURCE_CLIENT_SECRET=your-source-secret-here

# Target Tenant
TARGET_TENANT_ID=22222222-2222-2222-2222-222222222222
TARGET_CLIENT_ID=33333333-3333-3333-3333-333333333333
TARGET_CLIENT_SECRET=your-target-secret-here

# Azure Resources
AZURE_SUBSCRIPTION_ID=44444444-4444-4444-4444-444444444444
AZURE_RESOURCE_GROUP=migration-platform-rg

# Notifications
TEAMS_WEBHOOK=https://your-teams-webhook-url
